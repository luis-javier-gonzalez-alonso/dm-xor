# Maintainer: Luis Javier González Alonso <luis-javier-gonzalez-alonso@users.noreply.github.com>

pkgname=dm-xor-dkms
pkgver=2.1.0
pkgrel=1
pkgdesc="Device-mapper XOR split kernel module (DKMS)"
arch=('any')
url='https://github.com/luis-javier-gonzalez-alonso/dm-xor'
license=('GPL2')
depends=('dkms' 'linux-headers')
source=("$pkgname-$pkgver.tar.gz::https://github.com/luis-javier-gonzalez-alonso/dm-xor/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

package() {
    cd "dm-xor-$pkgver"

    install -d "$pkgdir/usr/src/dm-xor-$pkgver/"
    install -Dm644 dm-xor.c  "$pkgdir/usr/src/dm-xor-$pkgver/dm-xor.c"
    install -Dm644 Makefile         "$pkgdir/usr/src/dm-xor-$pkgver/Makefile"
    install -Dm644 dkms.conf        "$pkgdir/usr/src/dm-xor-$pkgver/dkms.conf"
}
